DJANGO_SECRET_KEY=replace-with-a-local-dev-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=true
ARGUS_AUTO_QUEUE_SCANS=true
PLAYWRIGHT_BROWSERS_PATH=.ms-playwright
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=replace-with-a-local-jwt-secret
JWT_ACCESS_TOKEN_LIFETIME=60

AI_PROVIDER=minimax
AI_MODEL=MiniMax-M2.7
AI_MAX_STEPS=20
AI_MAX_TOKENS=4096

# Google OAuth Client ID（一般使用者透過 Google 帳號登入時使用）
# 取得方式：Google Cloud Console > APIs & Services > Credentials > 建立 OAuth 用戶端 ID（Web application）
# 必須將 http://localhost:5173 與 http://localhost 加入「已授權的 JavaScript 來源」
# Backend 用於驗證 ID Token，Frontend 透過 Vite envPrefix 讀取同一個變數
GOOGLE_OAUTH_CLIENT_ID=

# 以下只填本機實際值；不可提交真正 API Key。
GLM_API_KEY=
MINIMAX_API_KEY=
GOOGLE_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=GoogleCloud_ApiKey.json

# Katana 補充型資安爬蟲（需安裝 Docker Desktop 並 pull 映像）
# docker pull projectdiscovery/katana:latest
KATANA_DOCKER_IMAGE=projectdiscovery/katana:latest
KATANA_TIMEOUT=90

# 首次 migrate 時自動建立的本機開發超級使用者（僅限本機；正式部署請留空並改用 createsuperuser）
ARGUS_BOOTSTRAP_SUPERUSER_USERNAME=
ARGUS_BOOTSTRAP_SUPERUSER_PASSWORD=
